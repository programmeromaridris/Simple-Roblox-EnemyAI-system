-- // =======================================================
-- // Initialize 
-- // =======================================================


function EnemyAI.Initialize(enemy, config)
	local humanoid = enemy:FindFirstChild("Humanoid")

	local attributes = {
		EnemyID = math.random(1, 50000),
		Damage = config.Damage,
		Cooldown = config.Cooldown,
		Range = config.Range,
		Hitbox = config.Hitbox,
		ProjSpeed = config.ProjSpeed,
		LastAttack = 0,
	}
	
	for name, value in pairs(attributes) do
		enemy:SetAttribute(name, value)
	end
	
	humanoid.MaxHealth = config.Health
	humanoid.Health = config.Health
	humanoid.WalkSpeed = config.Speed
	
	-- event listener that fires exaclty once when the enemy dies
	-- once cleans up the connection immediately after firing
	humanoid.Died:Once(function()
		StyleManager.AddStyle("Kill")
	end)
end





-- // =======================================================
-- // Enemy movement functions
-- // =======================================================


function EnemyAI.CheckLineOfSight(enemy, target)
	
	if not (enemy.PrimaryPart and target.PrimaryPart) then return end
	
	local hrpPos = enemy.PrimaryPart.Position
	local rayDirection = (target.PrimaryPart.Position - hrpPos)
	
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {enemy, workspace.Enemies}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	
	local result = workspace:Raycast(hrpPos, rayDirection, raycastParams)
	return result and result.Instance:IsDescendantOf(target) or false
end



-----------------------------------------------------
function EnemyAI.MoveWithPathfinding(enemy, targetPosition)
	local hum = enemy:FindFirstChild("Humanoid")
	if not (hum and enemy.PrimaryPart) then return end
	
	local path = PFS:CreatePath({AgentCanJump = true})
	enemy:SetAttribute("IsPathing", true) 
	
	local success, err = pcall(function()
		path:ComputeAsync(enemy.PrimaryPart.Position, targetPosition)
	end)
	
	if success and path.Status == Enum.PathStatus.Success then
		for _, waypoint in ipairs(path:GetWaypoints()) do
			if waypoint.Action == Enum.PathWaypointAction.Jump then
				hum.Jump = true
			end
			hum:MoveTo(waypoint.Position)
			hum.MoveToFinished:Wait()
		end
	else
		hum:MoveTo(targetPosition) -- fallback
	end
	enemy:SetAttribute("IsPathing", false) 
end



-- // =======================================================
-- // Enemy attack functions
-- // =======================================================


function EnemyAI.ShootProjectile(enemy, target, parryingPlayer)
	local hrp = enemy:FindFirstChild("HumanoidRootPart")
	local targethrp = target:FindFirstChild("HumanoidRootPart")
	if not (hrp and targethrp) or not EnemyAI.IsOffCooldown(enemy) then return end
	
	EnemyAI.ResetCooldown(enemy)
	
	local dmg = enemy:GetAttribute("Damage")
	local hitboxSize = enemy:GetAttribute("Hitbox")
	local speed = enemy:GetAttribute("ProjSpeed")
	local dir = (targethrp.Position - hrp.Position).Unit
	local offset = (EnemyAI.GetOffset()).Unit
	local startPos = hrp.Position + (dir * 3)
	
	-- visual projectile
	local proj = Instance.new("Part")
	proj.Size = Vector3.new(1, 1, 1) * hitboxSize
	proj.Shape = Enum.PartType.Ball
	proj.Color = Color3.fromRGB(255, 0, 0)
	proj.Material = Enum.Material.Neon
	proj.Anchored = true
	proj.CanCollide, proj.CanQuery = false, false
	proj.CFrame = CFrame.new(startPos)
	proj.Parent = workspace:FindFirstChild("Projectiles") or workspace
	Debris:AddItem(proj, 5)

	
	local isParried = false
	local connection = nil
	
	
	-- raycast
	local RayParams = RaycastParams.new()
	RayParams.FilterType = Enum.RaycastFilterType.Exclude
	
	connection = RS.Heartbeat:Connect(function(dt)
		if not proj.Parent then 
			connection:Disconnect()
			return
		end
		
		local distToMove = speed * dt
		local currentPos = proj.Position
		
		RayParams.FilterDescendantsInstances = isParried and {target} or {enemy, proj}
		local hitResult = workspace:Spherecast(currentPos, hitboxSize / 2, dir * distToMove, RayParams)
		proj.CFrame = proj.CFrame + (dir * distToMove)
		
		if hitResult then
			local character = hitResult.Instance.Parent
			local hitHum = character:FindFirstChild("Humanoid")
			
			if hitHum and hitHum.Health > 0 then
				if character == target then
					local player = Players:GetPlayerFromCharacter(character)
					if player and parryingPlayer[player] then
						isParried = true
						dir = -dir + offset
						speed *= 1.5
						StyleManager.AddStyle("Parry")
						return -- fly back
					else
						hitHum:TakeDamage(dmg)
						proj:Destroy()
						connection:Disconnect()
						return
					end
				elseif character == enemy and isParried then
					hitHum:TakeDamage(dmg * 2)
					StyleManager.AddStyle("Parry")
					proj:Destroy()
					connection:Disconnect()
					return
				end	
			elseif hitResult.Instance.CanCollide and hitResult.Instance.Name ~= "Baseplate" then
				proj:Destroy()
				connection:Disconnect()		
			end
		end
	end)
	
end


-----------------------------------------------------
function EnemyAI.Attack(enemy, target, parryingPlayer)
	local hrp = enemy:FindFirstChild("HumanoidRootPart")
	if not hrp or not EnemyAI.IsOffCooldown(enemy) then return end

		EnemyAI.ResetCooldown(enemy)
		-- reset the timer
		
		local dmg = enemy:GetAttribute("Damage")
		local hitbox = enemy:GetAttribute("Hitbox")
		local attackPos = (hrp.CFrame * CFrame.new(0, 0, -4)).Position
		
		-- params
		local overlapParams = OverlapParams.new()
		overlapParams.FilterDescendantsInstances = {enemy} -- dont count yourself
		overlapParams.FilterType = Enum.RaycastFilterType.Exclude
		
	local partsinHitbox = workspace:GetPartBoundsInBox(CFrame.new(attackPos), Vector3.new(1, 1, 1) * hitbox, overlapParams)
		local charactersHit = {}
		
		
	
		for _, part in ipairs(partsinHitbox) do
			local character = part.Parent
			local hitHum = character:FindFirstChild("Humanoid")
			
			if hitHum and hitHum.Health > 0 and not charactersHit[character] then
				charactersHit[character] = true -- theyre hit
			
			local player = Players:GetPlayerFromCharacter(character) 
			if player and not parryingPlayer[player] then
				hitHum:TakeDamage(dmg)
			end
		end
	end
end








-- // =======================================================
-- // Enemy movement functions
-- // =======================================================

-----------------------------------------------------
function EnemyAI.RangeMove(enemy, target, dist, parryingPlayer)
	local hrp = enemy:FindFirstChild("HumanoidRootPart")
	local targetHrp = target:FindFirstChild("HumanoidRootPart")
	if not (hrp and targetHrp) then return end
	
	local range = enemy:GetAttribute("Range")
	local hasLoS = EnemyAI.CheckLineOfSight(enemy, target)
	
	
	if hasLoS and dist <= range then
		EnemyAI.ShootProjectile(enemy, target, parryingPlayer)
	end
	
	if not enemy:GetAttribute("IsPathing") then
		
		if dist < (range * 0.7) then
			local retreatPos = targetHrp.Position + ((hrp.Position - targetHrp.Position).Unit * range)
			EnemyAI.MoveWithPathfinding(enemy, retreatPos + EnemyAI.GetSurroundOffset(enemy))
		elseif dist > (range + 2) then
			EnemyAI.MoveWithPathfinding(enemy, targetHrp.Position + EnemyAI.GetSurroundOffset(enemy))
		else
			EnemyAI.StayStill(enemy)
		end		
		
	end
end


-----------------------------------------------------
function EnemyAI.Move(enemy, target, dist, parryingPlayer)
	if not (enemy.PrimaryPart and target.PrimaryPart) then return end
	local range = enemy:GetAttribute("Range")
	
	if EnemyAI.CheckLineOfSight(enemy, target) then
		enemy:SetAttribute("LastKnownPos", target.PrimaryPart.Position)
		
		if dist <= range then
			EnemyAI.Attack(enemy, target, parryingPlayer)
			EnemyAI.StayStill(enemy)
			
		elseif not enemy:GetAttribute("IsPathing") then
			EnemyAI.MoveWithPathfinding(enemy, target.PrimaryPart.Position + EnemyAI.GetSurroundOffset(enemy))
		end
		
	else
		enemy:SetAttribute("LastKnownPos", nil)
	end
end


return EnemyAI
