local PFS = game:GetService("PathfindingService")
local Players = game:GetService("Players")
local Debris = game:GetService("Debris")
local RS = game:GetService("RunService")
local StyleManager = require(game.ReplicatedStorage.Modules.StyleManager)
local PlayerState = require(game.ReplicatedStorage.Modules.PlayerState)

local EnemyAI = {}


-- // helper functions
-----------------------------------------------------
function EnemyAI.StayStill(enemy)
	local humanoid = enemy:FindFirstChild("Humanoid")
	if humanoid then
		humanoid:MoveTo(enemy.PrimaryPart.Position)
	end
end

-----------------------------------------------------
function EnemyAI.IsOffCooldown(enemy)
	local last = enemy:GetAttribute("LastAttack")
	return tick() - last >= enemy:GetAttribute("Cooldown")
end



-----------------------------------------------------
function EnemyAI.ResetCooldown(enemy)
	enemy:SetAttribute("LastAttack", tick())
end




-----------------------------------------------------
function EnemyAI.GetSurroundOffset(enemy)

	local seed = enemy:GetAttribute("EnemyID")
	local angle = (seed * 137.5) % 360
	local radius = 6
	return Vector3.new(math.cos(math.rad(angle)) * radius, 0, math.sin(math.rad(angle)) * radius)

end


function EnemyAI.GetOffset(enemy)

	local seed = math.random(1, 5)
	local angle = (seed * 137.5) % 360
	local radius = 6
	return Vector3.new(math.cos(math.rad(angle)) * radius, 0, math.sin(math.rad(angle)) * radius)

end

-----------------------------------------------------
function EnemyAI.GetClosestPlayer(enemyPart)
	if not enemyPart then warn("I can't find the enemyPart!") return end
	local closestPlayer = nil
	local shortestDist = math.huge

	for _, player in pairs(Players:GetPlayers()) do
		local char = player.Character
		local hum = char:FindFirstChild("Humanoid")
		
		if char and hum and hum.Health > 0 then 
			local dist = (enemyPart.Position - char.PrimaryPart.Position).Magnitude
			if dist < shortestDist then 
				shortestDist = dist
				closestPlayer = char
			end
		end
	end
	return closestPlayer, shortestDist
end


