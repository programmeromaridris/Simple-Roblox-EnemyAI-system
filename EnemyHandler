for _, trigger in ipairs(workspace.EnemyTriggers:GetChildren()) do
	local connection
	
	connection = trigger.Touched:Connect(function(hit)
		local player = Players:GetPlayerFromCharacter(hit.Parent)
		if not player then return end 
		
		connection:Disconnect() -- only disconnect after a confirmed player touch
		
			print("There's a player in me!")
			local enemyToSpawn = trigger:GetAttribute("EnemyType")
			local amountToSpawn = trigger:GetAttribute("Amount") 
			local whereToSpawn = trigger:GetAttribute("SpawnLocation") 
			
			SpawnEnemy(enemyToSpawn, whereToSpawn, amountToSpawn)
			trigger:Destroy()
	end)
end
 
 
 -- // Main AI loop
-----------------------------------------------------
 while task.wait(0.001) do
		for enemy, data in pairs(activeEnemies) do
			-- Fast checks
			if data.hum.Health <= 0 then
				
				-- this is ugly and prolly convoluted but eh who gives a care
				local healthToGain, targetPlayer = CalculateHealthToGain(data.hrp)
				
				if healthToGain > 0 and targetPlayer then
					local char = targetPlayer.Character
					local hum = char:FindFirstChild("Humanoid")
					
					if hum then 
						hum.Health = math.min(hum.Health + healthToGain, 100)
					end
				end
				
				activeEnemies[enemy] = nil -- Remove from the enemy loop
				enemy:SetAttribute("Dying", true)
				Debris:AddItem(enemy, 1)
				print("Enemy died! Adding... " .. healthToGain)
				
				-- You can notify the enemydied event here for visual ui
				-- EnemyDied:FireClient(enemy)
				continue
			end
			
			
		-- Execute AI logic in a separate thread so yielding doesn't block other enemies
		task.spawn(function()
			local target, dist = EnemyAI.GetClosestPlayer(data.hrp)
			if not target then return end 
			
				if data.config.EnemyRange == "Ranged" then
					EnemyAI.RangeMove(enemy, target, dist, parryingPlayer)
				elseif data.config.EnemyRange == "Short" then
					EnemyAI.Move(enemy, target, dist, parryingPlayer)
			end
		end)
	end
 end
