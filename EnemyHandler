SlamHitEvent.OnServerEvent:Connect(function(player, hitHum)
	if not hitHum then return end
	local SLAM_DAMAGE = 50
	
	if hitHum:IsA("Humanoid") and hitHum.Health > 0 then
	hitHum:TakeDamage(SLAM_DAMAGE)
	end
end)

PlayerParrying.OnServerEvent:Connect(function(player, isParrying)
	parryingPlayer[player] = isParrying
end)

-- Prevent memory leaks
Players.PlayerRemoving:Connect(function(player)
	parryingPlayer[player] = nil
end)






