-- TODO spawn multiple enemies in different places based off the same trigger touch
local function SpawnEnemy(typeName, spawnLocation, amount)
	amount = amount or 1
	local config = EnemyTypes[typeName]
	if not config then warn("No config found for: " .. tostring(typeName)) return end
	
	for i = 1, amount do
		local newEnemy = SS.EnemyModels.Rig:Clone() 
		newEnemy.Name = typeName
		newEnemy:SetAttribute("EnemyType", typeName)
		-- For the future, change to config.Model (since enemy model will be in it's config)
		
		EnemyAI.Initialize(newEnemy, config)
		
		local offset = Vector3.new(math.random(-2, 2), 0, math.random(-2, 2))
		newEnemy:PivotTo(CFrame.new(spawnLocation + offset))
		
		-- Cache essential components
		local hrp = newEnemy:WaitForChild("HumanoidRootPart")
		local hum = newEnemy:WaitForChild("Humanoid")
		
		newEnemy.Parent = EnemyFolder
		hrp:SetNetworkOwner(nil)
		
		-- Add to our loop tracking table
		activeEnemies[newEnemy] = {
			hrp = hrp,
			hum = hum,
			config = config
		}
	end
end


-- Initialization
