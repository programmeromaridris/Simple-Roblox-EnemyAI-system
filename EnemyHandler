-- // Helpers


local function GetClosestPlayer(enemyHRP)
	local closestPlayer = nil
	local shortestDist = math.huge
	
	for _, player in pairs(Players:GetPlayers()) do
		local char = player.Character
		local hum = char:FindFirstChild("Humanoid")

		if char and hum and hum.Health > 0 then 
			local dist = (enemyHRP.Position - char.PrimaryPart.Position).Magnitude
			if dist < shortestDist then 
				shortestDist = dist
				closestPlayer = player
			end
		end
	end
	return closestPlayer, shortestDist
end


local function CalculateHealthToGain(enemyHRP)
	local closestPlayer, shortestDist = GetClosestPlayer(enemyHRP)

	local hpToIncrement = 10
	local HealthToGain = 0

	if shortestDist > 100 then
		return 0, closestPlayer
	end


	-- Expotential multiplier
	-- if 100 studs, multiply by 0, if 90, by 10, etc etc.

	-- Example: At 100 studs, (100-100)/10 = 0 -> 2^0 = 1 -> 1 * 0.5 = 0.5
	local exponent = (100 - shortestDist) / 10
	local multiplier = 0.5 * (1.3 ^ exponent)

	HealthToGain = hpToIncrement * multiplier
	return HealthToGain, closestPlayer
end



